# ─── Backend API URL (Render) ─────────────────────────────
# Point to your deployed Render backend URL (no trailing slash)
# In production this should end with /api
VITE_API_BASE_URL=https://YOUR_RENDER_APP_NAME.onrender.com/api

# ─── NVIDIA NIM API ───────────────────────────────────────
VITE_NVIDIA_API_KEY=nvapi-your_nvidia_api_key

# ─── Google Gemini (Fallback AI) ──────────────────────────
VITE_GEMINI_API_KEY=your_gemini_api_key

# ─── HuggingFace ──────────────────────────────────────────
VITE_HF_TOKEN=hf_your_token_here
